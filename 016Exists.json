{
	"name": "016Exists",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "014Lookupsales",
						"type": "DatasetReference"
					},
					"name": "readSales"
				},
				{
					"dataset": {
						"referenceName": "015Products",
						"type": "DatasetReference"
					},
					"name": "readProducts"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "016Exists",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "exists1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          ProductKey as short,",
				"          CustomerKey as short,",
				"          SalesAmount as double",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> readSales",
				"source(output(",
				"          ProductKey as short,",
				"          EnglishProductName as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> readProducts",
				"readSales, readProducts exists(readSales@ProductKey == readProducts@ProductKey,",
				"     negate:false,",
				"     broadcast: 'auto')~> exists1",
				"exists1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}