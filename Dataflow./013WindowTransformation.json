{
	"name": "013WindowTransformation",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ordercsv1",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "013WIndow",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "window1"
				},
				{
					"name": "AggregateDateWise"
				}
			],
			"scriptLines": [
				"source(output(",
				"          OrderDate as date,",
				"          ProductKey as short,",
				"          Country as string,",
				"          EnglishProductName as string,",
				"          SalesAmount as double,",
				"          UnitPrice as double,",
				"          OrderQuantity as boolean,",
				"          TaxAmt as double,",
				"          TotalProductCost as double",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> source1",
				"AggregateDateWise window(over(year = year(OrderDate),",
				"          month = month(OrderDate)),",
				"     asc(OrderDate, true),",
				"     CummSales = sum(TotalSales),",
				"     partitionBy('hash', 1)) ~> window1",
				"source1 aggregate(groupBy(OrderDate),",
				"     TotalSales = sum(SalesAmount)) ~> AggregateDateWise",
				"window1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}